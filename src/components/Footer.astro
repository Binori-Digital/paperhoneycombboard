---
const { activePage = '' } = Astro.props;
const links = [
  { href: '/regional/', label: 'JB Solutions' },
  { href: '/regional/', label: 'KL Logistics' },
  { href: '/regional/', label: 'Singapore Green' },
  { href: '/eco-lab/', label: 'The Eco-Lab' },
  { href: '/combat-zone/', label: 'Ditch the Wood' },
  { href: '/privacy/', label: 'Privacy' },
  { href: '/terms/', label: 'Terms' },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo">HexaEco</a>
      <p class="footer__copy">© 2024 HexaEco. Industrial Structural Integrity.</p>
    </div>
    <nav aria-label="Footer navigation">
      <ul class="footer__links">
        {links.map(link => (
          <li><a href={link.href} class="footer__link">{link.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</footer>

<style>
  .footer {
    background: #0a0a0a;
    color: #fff;
    padding: 2rem 0;
  }
  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .footer__logo {
    font-size: 1.1rem;
    font-weight: 800;
    color: #39FF14;
    display: block;
    margin-bottom: 0.25rem;
  }
  .footer__copy {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #666;
  }
  .footer__links {
    display: flex;
    list-style: none;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }
  .footer__link {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #888;
    transition: color 0.15s;
  }
  .footer__link:hover { color: #39FF14; }
</style>
