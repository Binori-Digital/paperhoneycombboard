---
const navLinks = [
  { href: '/', label: 'Industry Solutions' },
  { href: '/eco-lab/', label: 'The Eco-Lab' },
  { href: '/combat-zone/', label: 'Combat Zone' },
];
const { currentPath = '' } = Astro.props;
const path = Astro.url?.pathname ?? currentPath;
---

<header class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__logo" aria-label="PHB - Paper Honeycomb Board">phb.</a>
    <nav aria-label="Main navigation">
      <ul class="nav__links">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['nav__link', { 'nav__link--active': path === link.href || (link.href !== '/' && path.startsWith(link.href)) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <a href="/contact/" class="btn btn--green nav__cta">Get a Hex-Sample Kit</a>
    <button class="nav__burger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 2px solid #0a0a0a;
  }
  .nav__inner {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    height: 64px;
  }
  .nav__logo {
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    flex-shrink: 0;
    margin-right: auto;
  }
  .nav__links {
    display: flex;
    list-style: none;
    gap: 2rem;
  }
  .nav__link {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #666;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  .nav__link:hover { color: #0a0a0a; }
  .nav__link--active { color: #0a0a0a; border-bottom-color: #0a0a0a; }
  .nav__cta { padding: 0.5rem 1.25rem; font-size: 0.7rem; }
  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    padding: 4px;
    cursor: pointer;
  }
  .nav__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #0a0a0a;
  }

  @media (max-width: 768px) {
    .nav__links { display: none; }
    .nav__cta { display: none; }
    .nav__burger { display: flex; }
    .nav__logo { margin-right: 0; }
  }
</style>

<script>
  const burger = document.querySelector('.nav__burger') as HTMLButtonElement;
  const navLinks = document.querySelector('.nav__links') as HTMLElement;
  burger?.addEventListener('click', () => {
    const expanded = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!expanded));
    navLinks.style.display = expanded ? '' : 'flex';
    navLinks.style.flexDirection = 'column';
    navLinks.style.position = 'absolute';
    navLinks.style.top = '64px';
    navLinks.style.left = '0';
    navLinks.style.width = '100%';
    navLinks.style.background = '#fff';
    navLinks.style.padding = '1rem 2rem';
    navLinks.style.borderBottom = '2px solid #0a0a0a';
  });
</script>
