---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "The Eco-Lab – Creative Structural Panels | HexaEco",
  "description": "Where structure meets soul. Engineer high-strength honeycomb cardboard into architectural-grade solutions for creators, designers, and studios.",
  "url": "https://www.paperhoneycombboard.com/eco-lab/",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.paperhoneycombboard.com/" },
      { "@type": "ListItem", "position": 2, "name": "The Eco-Lab" }
    ]
  }
};
---

<Layout
  title="The Eco-Lab – Creative Structural Panels | HexaEco"
  description="Where structure meets soul. Engineer high-strength honeycomb cardboard into architectural-grade panels. 85% weight reduction. 12kN compression force. 100% recyclable art materials."
  canonical="/eco-lab/"
  schema={schema}
>
  <!-- HERO -->
  <section class="hero" aria-labelledby="ecolab-heading">
    <div class="container hero__grid">
      <div>
        <span class="badge">The Eco-Lab</span>
        <h1 class="hero__title" id="ecolab-heading">Where Structure<br />Meets Soul</h1>
        <p class="hero__desc">
          Not just a box — a building block for your next masterpiece. We engineer high-strength
          honeycomb cardboard into architectural-grade solutions for creators.
        </p>
        <div class="hero__actions">
          <a href="/contact/" class="btn btn--green">Get a Hex-Sample Kit for Your Studio</a>
        </div>
      </div>
      <div class="hero__img-wrap">
        <img
          src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&q=80"
          alt="Sculptural honeycomb paper structure – architectural art installation"
          width="600" height="450"
          loading="eager"
          fetchpriority="high"
        />
        <div class="hero__stat-badge">
          <strong>100%</strong>
          <p>Recyclable Strength</p>
        </div>
      </div>
    </div>
  </section>

  <!-- INDUSTRIAL AESTHETICS -->
  <section class="section" aria-labelledby="aesthetics-heading">
    <div class="container">
      <h2 id="aesthetics-heading">Industrial Aesthetics</h2>
      <p class="section-desc">Our material technology bridges the gap between temporary installations and permanent structural integrity.</p>

      <div class="grid-2" style="margin-top:2.5rem">
        <article class="feature-card">
          <div class="feature-card__icon">🏗️</div>
          <h3 class="feature-card__title">Lightweight Structural Panels</h3>
          <p class="feature-card__text">
            Rigid enough for load-bearing architecture, light enough for one-person assembly.
            Engineered with hexagonal core precision.
          </p>
          <div class="card-img">
            <img
              src="https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=600&q=80"
              alt="Cross-section of honeycomb paper panel showing hexagonal core structure"
              width="500" height="300"
              loading="lazy"
            />
          </div>
        </article>

        <article class="feature-card feature-card--peach">
          <div class="feature-card__icon" style="background:#0a0a0a">♻️</div>
          <h3 class="feature-card__title">100% Recyclable Art Materials</h3>
          <p class="feature-card__text">
            Premium Kraft finish that accepts all mediums — from industrial paint to fine graphite.
            Zero-waste creativity for the modern studio.
          </p>
          <div class="card-imgs-grid">
            <img
              src="https://images.unsplash.com/photo-1541961017774-22349e4a1262?w=300&q=80"
              alt="Art installation using paper honeycomb panels"
              width="250" height="180"
              loading="lazy"
            />
            <img
              src="https://images.unsplash.com/photo-1572947650440-e8a97ef053b2?w=300&q=80"
              alt="Interior design installation with honeycomb structural panels"
              width="250" height="180"
              loading="lazy"
            />
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- PROTOTYPING EXCELLENCE -->
  <section class="section section--dark" aria-labelledby="proto-heading">
    <div class="container proto-grid">
      <div>
        <span class="badge">Prototyping Excellence</span>
        <h2 id="proto-heading">Custom Structural Mockups</h2>
        <p style="color:#aaa;margin:1rem 0 1.5rem;line-height:1.7">
          Validate your vision in 1:1 scale before committing to expensive materials. Our panels
          provide real-world feedback on tension and compression.
        </p>
        <a href="/contact/" style="font-weight:700;color:#39FF14;font-size:0.85rem;letter-spacing:0.05em;text-transform:uppercase">
          View Technical Specs →
        </a>
      </div>
      <div class="proto-stats">
        <div class="stat-box">
          <div class="stat-box__value">85%</div>
          <div class="stat-box__label">Weight Reduction</div>
        </div>
        <div class="stat-box">
          <div class="stat-box__value">12KN</div>
          <div class="stat-box__label">Compression Force</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FURNITURE AS ARCHITECTURE -->
  <section class="section" aria-labelledby="furniture-heading">
    <div class="container feature-row">
      <div class="feature-row__img">
        <img
          src="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=700&q=80"
          alt="Sculptural cardboard furniture – honeycomb paper chair laser-cut and hand-finished"
          width="600" height="500"
          loading="lazy"
        />
        <span class="img-badge">Furniture Series 01</span>
      </div>
      <div class="feature-row__content">
        <h2 id="furniture-heading" class="furniture-title">Furniture as<br />Architecture</h2>
        <div class="furniture-features">
          <div class="furniture-feature">
            <div class="feature-card__icon" style="flex-shrink:0">🪑</div>
            <div>
              <strong>Artisanal Utility</strong>
              <p>Furniture that functions as sculptural art. Each piece is laser-cut and hand-finished in our Singapore facility.</p>
            </div>
          </div>
          <div class="furniture-feature">
            <div class="feature-card__icon" style="flex-shrink:0">🎪</div>
            <div>
              <strong>Modular Playhouses</strong>
              <p>Complex structural systems simplified for temporary creative spaces, pop-up events, and immersive art galleries.</p>
            </div>
          </div>
        </div>
        <a href="/contact/" class="btn btn--dark" style="margin-top:2rem;align-self:flex-start">Explore the Collection</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--green cta-block" aria-labelledby="cta-heading">
    <div class="container">
      <h2 id="cta-heading" class="cta-block__title">Ready to build?</h2>
      <p class="cta-block__desc">
        Request our architect-grade sample kit including three densities of structural honeycomb and our finish guide.
      </p>
      <div class="cta-block__actions">
        <a href="/contact/" class="btn btn--dark">Get Your Kit</a>
        <a href="/contact/" class="btn btn--outline">Talk to an Engineer</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .section-desc { color: #666; max-width: 600px; margin-top: 0.5rem; line-height: 1.7; }
  .card-img { margin-top: 1.5rem; border: 2px solid #0a0a0a; overflow: hidden; }
  .card-img img { width: 100%; object-fit: cover; }
  .card-imgs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-top: 1.5rem; }
  .card-imgs-grid img { width: 100%; object-fit: cover; }

  .proto-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .proto-stats { display: flex; gap: 1.5rem; flex-wrap: wrap; }

  .img-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: #39FF14;
    color: #000;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
  }
  .feature-row__img { position: relative; }

  .furniture-title { font-size: clamp(2rem, 4vw, 3rem); text-transform: uppercase; }
  .furniture-features { display: flex; flex-direction: column; gap: 1.5rem; margin-top: 1.5rem; }
  .furniture-feature { display: flex; gap: 0.75rem; align-items: flex-start; }
  .furniture-feature p { font-size: 0.85rem; color: #666; margin-top: 0.2rem; }

  @media (max-width: 768px) {
    .proto-grid { grid-template-columns: 1fr; gap: 2rem; }
    .proto-stats { gap: 1rem; }
  }
</style>
