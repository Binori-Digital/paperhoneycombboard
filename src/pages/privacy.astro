---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Privacy Policy | HexaEco" description="Privacy policy for HexaEco Paper Honeycomb Board website." canonical="/privacy/" noindex={true}>
  <section class="section"><div class="container" style="max-width:720px">
    <h1>Privacy Policy</h1>
    <p style="color:#666;margin:1rem 0 2rem">Last updated: January 2024</p>
    <p>HexaEco Paper Honeycomb Board ("we", "us") respects your privacy. This policy explains how we collect and use information on www.paperhoneycombboard.com.</p>
    <h2 style="margin:2rem 0 0.75rem">Information We Collect</h2>
    <p>We collect information you provide via our contact form (name, email, company, message). We do not sell or share personal data with third parties.</p>
    <h2 style="margin:2rem 0 0.75rem">Cookies</h2>
    <p>This website uses minimal cookies for analytics purposes only. No advertising cookies are used.</p>
    <h2 style="margin:2rem 0 0.75rem">Contact</h2>
    <p>For privacy inquiries, contact us via the <a href="/contact/" style="text-decoration:underline">contact page</a>.</p>
  </div></section>
</Layout>
